# Copia este archivo como .env (local) y/o pon estas variables en Vercel.

# --- IA (Brody) — sigue en Supabase ---
# URL de la Edge Function de Supabase que hace de proxy de la IA:
VITE_AI_ENDPOINT=https://TU-PROYECTO.supabase.co/functions/v1/chat
# Clave pública (anon) de Supabase — la usa la IA para llamar al proxy:
VITE_SUPABASE_ANON_KEY=tu_anon_key

# --- Login (Firebase Auth) — al ponerlas, la app exige iniciar sesión ---
# Ver SETUP-FIREBASE.md. Son públicas (van en el frontend), no son secretos.
VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
