# Copia este archivo como .env (local) y/o pon estas variables en Vercel.
# URL de la Edge Function de Supabase que hace de proxy de la IA:
VITE_AI_ENDPOINT=https://TU-PROYECTO.supabase.co/functions/v1/chat

# Login (Supabase Auth). Al ponerlas, la app exige iniciar sesión (ver SETUP-AUTH.md):
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key
